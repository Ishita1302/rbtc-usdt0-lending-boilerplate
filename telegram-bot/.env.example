# Required — from @BotFather
TELEGRAM_BOT_TOKEN=

# Rootstock JSON-RPC (aliases: RSK_RPC_URL or ROOTSTOCK_RPC_URL)
RSK_RPC_URL=https://public-node.testnet.rsk.co

# Deployed contracts (match frontend/.env or your deployment)
LENDING_POOL_ADDRESS=0xC09Fe81b40DB2a013017bc2BcFfc718A25C45Cd3
USDT0_ADDRESS=0xf7F1Fe4c7dea6401Ae4e486502832782247E7A0f

# Hardhat artifact JSON paths (absolute, or relative to telegram-bot/). Defaults:
# ../artifacts/contracts/LendingPool.sol/LendingPool.json
# ../artifacts/contracts/tokens/MockUSDT0.sol/MockUSDT0.json
# LENDING_POOL_ARTIFACT_PATH=
# USDT0_ARTIFACT_PATH=

# READ_ONLY_MODE=true — ignore PRIVATE_KEY; write commands not registered
# READ_ONLY_MODE=

# If PRIVATE_KEY is set, require either an allow-list OR explicit public-write danger flag:
# ALLOWED_TELEGRAM_IDS=123456789,987654321
# DANGEROUS_ALLOW_PUBLIC_WRITES=true

# Chain policy: default is Rootstock testnet (chainId 31) only.
# I_UNDERSTAND_THE_RISK=true
# ALLOWED_CHAIN_IDS=31

# Optional tuning
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=20
# TX_CONFIRM_TIMEOUT_MS=60000

# Optional — signs /deposit, /withdraw, /borrow, /approve, /repay (operator wallet)
# PRIVATE_KEY=
# BOT_PRIVATE_KEY=
