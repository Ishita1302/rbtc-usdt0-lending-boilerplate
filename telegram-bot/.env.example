# Required — from @BotFather
TELEGRAM_BOT_TOKEN=

# Rootstock JSON-RPC (aliases: RSK_RPC_URL or ROOTSTOCK_RPC_URL)
RSK_RPC_URL=https://public-node.testnet.rsk.co

# Deployed contracts (match frontend/.env or your deployment)
LENDING_POOL_ADDRESS=0xC09Fe81b40DB2a013017bc2BcFfc718A25C45Cd3
USDT0_ADDRESS=0xf7F1Fe4c7dea6401Ae4e486502832782247E7A0f

# Hardhat artifact JSON paths (absolute, or relative to telegram-bot/). Defaults:
# ../artifacts/contracts/LendingPool.sol/LendingPool.json
# ../artifacts/contracts/tokens/MockUSDT0.sol/MockUSDT0.json
# LENDING_POOL_ARTIFACT_PATH=
# USDT0_ARTIFACT_PATH=

# Optional — signs /deposit, /withdraw, /borrow, /approve, /repay (testnet only)
# PRIVATE_KEY=
# BOT_PRIVATE_KEY=
